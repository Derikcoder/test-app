{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wkd.local/schemas/invoice.schema.v1.1.json",
  "title": "WKD Invoice Schema v1.1 (Normalized)",
  "description": "Normalized snake_case schema without special characters in keys.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/invoice"
  },
  "$defs": {
    "invoice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_provider_details",
        "client_details",
        "invoice_details",
        "service_details",
        "billing_and_costing",
        "service_description"
      ],
      "properties": {
        "service_provider_details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/serviceProviderDetails"
          }
        },
        "client_details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/clientDetails"
          }
        },
        "invoice_details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/invoiceDetails"
          }
        },
        "service_details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/serviceDetails"
          }
        },
        "billing_and_costing": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/billingAndCosting"
          }
        },
        "service_description": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "serviceProviderDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_trade_name",
        "business_registered_name",
        "tax_identification_number",
        "vat_registration_number",
        "business_address",
        "business_contact_number",
        "business_email_address",
        "business_website"
      ],
      "properties": {
        "business_trade_name": {
          "type": "string",
          "minLength": 1
        },
        "business_registered_name": {
          "type": "string",
          "minLength": 1
        },
        "tax_identification_number": {
          "type": "string",
          "minLength": 1
        },
        "vat_registration_number": {
          "type": "string",
          "minLength": 1
        },
        "business_address": {
          "type": "string",
          "minLength": 1
        },
        "business_contact_number": {
          "type": "string",
          "minLength": 1
        },
        "business_email_address": {
          "type": "string",
          "format": "email"
        },
        "business_website": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "clientDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client_type",
        "business_name",
        "business_registration_number",
        "tax_identification_number",
        "vat_registration_number",
        "client_address",
        "contact_person",
        "client_contact_number",
        "client_email_address"
      ],
      "properties": {
        "client_type": {
          "type": "string",
          "minLength": 1
        },
        "business_name": {
          "type": "string",
          "minLength": 1
        },
        "business_registration_number": {
          "type": "string",
          "minLength": 1
        },
        "tax_identification_number": {
          "type": "string",
          "minLength": 1
        },
        "vat_registration_number": {
          "type": "string",
          "minLength": 1
        },
        "client_address": {
          "type": "string",
          "minLength": 1
        },
        "contact_person": {
          "type": "string",
          "minLength": 1
        },
        "client_contact_number": {
          "type": "string",
          "minLength": 1
        },
        "client_email_address": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "invoiceDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invoice_number",
        "invoice_date",
        "due_date",
        "payment_terms",
        "currency"
      ],
      "properties": {
        "invoice_number": {
          "type": "string",
          "minLength": 1
        },
        "invoice_date": {
          "type": "string",
          "format": "date"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "payment_terms": {
          "type": "string",
          "minLength": 1
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "serviceDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_summary",
        "machine_details"
      ],
      "properties": {
        "service_summary": {
          "type": "string",
          "minLength": 1
        },
        "machine_details": {
          "$ref": "#/$defs/machineDetails"
        }
      }
    },
    "machineDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "machine_type",
        "machine_brand",
        "machine_model",
        "machine_serial_number",
        "kva_rating",
        "current_machine_hours",
        "machine_hours_at_last_service",
        "fuel_type",
        "build_type",
        "machine_fault_code",
        "fault_code_description",
        "last_service_date_reference"
      ],
      "properties": {
        "machine_type": {
          "type": "string",
          "minLength": 1
        },
        "machine_brand": {
          "type": "string",
          "minLength": 1
        },
        "machine_model": {
          "type": "string",
          "minLength": 1
        },
        "machine_serial_number": {
          "type": "string",
          "minLength": 1
        },
        "kva_rating": {
          "type": "string",
          "minLength": 1
        },
        "current_machine_hours": {
          "type": "string",
          "minLength": 1
        },
        "machine_hours_at_last_service": {
          "type": "string",
          "minLength": 1
        },
        "fuel_type": {
          "type": "string",
          "minLength": 1
        },
        "build_type": {
          "type": "string",
          "minLength": 1
        },
        "machine_fault_code": {
          "type": "string",
          "minLength": 1
        },
        "fault_code_description": {
          "type": "string",
          "minLength": 1
        },
        "last_service_date_reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "billingAndCosting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line_items",
        "fixed_expenses",
        "invoice_totals"
      ],
      "properties": {
        "line_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/lineItem"
          }
        },
        "fixed_expenses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fixedExpense"
          }
        },
        "invoice_totals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/invoiceTotals"
          }
        }
      }
    },
    "lineItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "part_type",
        "manufacturer",
        "part_number",
        "unit_cost",
        "quantity",
        "total_cost",
        "part_description"
      ],
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "part_type": {
          "type": "string",
          "minLength": 1
        },
        "manufacturer": {
          "type": "string",
          "minLength": 1
        },
        "part_number": {
          "type": "string",
          "minLength": 1
        },
        "unit_cost": {
          "type": "number",
          "minimum": 0
        },
        "quantity": {
          "type": "number",
          "minimum": 0
        },
        "total_cost": {
          "type": "number",
          "minimum": 0
        },
        "part_description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "fixedExpense": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "callout_fee_per_km",
        "distance_km",
        "minimum_callout_fee",
        "callout_fee_total"
      ],
      "properties": {
        "callout_fee_per_km": {
          "type": "number",
          "minimum": 0
        },
        "distance_km": {
          "type": "number",
          "minimum": 0
        },
        "minimum_callout_fee": {
          "type": "number",
          "minimum": 0
        },
        "callout_fee_total": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "invoiceTotals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subtotal": {
          "type": "number",
          "minimum": 0
        },
        "vat_rate": {
          "type": "number",
          "minimum": 0
        },
        "vat_amount": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        },
        "deposit_amount": {
          "type": "number",
          "minimum": 0
        },
        "balance_due": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
