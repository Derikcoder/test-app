{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wkd.local/schemas/invoice.schema.v1.1.json",
  "title": "WKD Invoice Schema v1.1 (Normalized)",
  "description": "Normalized snake_case schema aligned to the structured invoiced-details model with sundry expenses, fixed expenses, VAT totals, and consumables sliding-scale metadata.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/invoice"
  },
  "$defs": {
    "invoice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_provider_details",
        "client_details",
        "invoice_details",
        "service_details",
        "billing_and_costing",
        "service_description"
      ],
      "properties": {
        "service_provider_details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/serviceProviderDetails"
          }
        },
        "client_details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/clientDetails"
          }
        },
        "invoice_details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/invoiceDetails"
          }
        },
        "service_details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/serviceDetails"
          }
        },
        "billing_and_costing": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/billingAndCosting"
          }
        },
        "service_description": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "serviceProviderDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_trade_name",
        "business_registered_name",
        "tax_identification_number",
        "vat_registration_number",
        "business_address",
        "business_contact_number",
        "business_email_address",
        "business_website"
      ],
      "properties": {
        "business_trade_name": {
          "type": "string",
          "minLength": 1
        },
        "business_registered_name": {
          "type": "string",
          "minLength": 1
        },
        "tax_identification_number": {
          "type": "string",
          "minLength": 1
        },
        "vat_registration_number": {
          "type": "string",
          "minLength": 1
        },
        "business_address": {
          "type": "string",
          "minLength": 1
        },
        "business_contact_number": {
          "type": "string",
          "minLength": 1
        },
        "business_email_address": {
          "type": "string",
          "format": "email"
        },
        "business_website": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "clientDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client_type",
        "business_name",
        "business_registration_number",
        "tax_identification_number",
        "vat_registration_number",
        "client_address",
        "contact_person",
        "client_contact_number",
        "client_email_address"
      ],
      "properties": {
        "client_type": {
          "type": "string",
          "minLength": 1
        },
        "business_name": {
          "type": "string",
          "minLength": 1
        },
        "business_registration_number": {
          "type": "string",
          "minLength": 1
        },
        "tax_identification_number": {
          "type": "string",
          "minLength": 1
        },
        "vat_registration_number": {
          "type": "string",
          "minLength": 1
        },
        "client_address": {
          "type": "string",
          "minLength": 1
        },
        "contact_person": {
          "type": "string",
          "minLength": 1
        },
        "client_contact_number": {
          "type": "string",
          "minLength": 1
        },
        "client_email_address": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "invoiceDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invoice_number",
        "invoice_date",
        "due_date",
        "payment_terms",
        "currency"
      ],
      "properties": {
        "invoice_number": {
          "type": "string",
          "minLength": 1
        },
        "invoice_date": {
          "type": "string",
          "format": "date"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "payment_terms": {
          "type": "string",
          "minLength": 1
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "serviceDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_summary",
        "machine_details"
      ],
      "properties": {
        "service_summary": {
          "type": "string",
          "minLength": 1
        },
        "machine_details": {
          "$ref": "#/$defs/machineDetails"
        }
      }
    },
    "machineDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "machine_type",
        "machine_brand",
        "machine_model",
        "machine_serial_number",
        "kva_rating",
        "current_machine_hours",
        "machine_hours_at_last_service",
        "fuel_type",
        "build_type",
        "machine_fault_code",
        "fault_code_description",
        "last_service_date_reference"
      ],
      "properties": {
        "machine_type": {
          "type": "string",
          "minLength": 1
        },
        "machine_brand": {
          "type": "string",
          "minLength": 1
        },
        "machine_model": {
          "type": "string",
          "minLength": 1
        },
        "machine_serial_number": {
          "type": "string",
          "minLength": 1
        },
        "kva_rating": {
          "type": "string",
          "minLength": 1
        },
        "current_machine_hours": {
          "type": "string",
          "minLength": 1
        },
        "machine_hours_at_last_service": {
          "type": "string",
          "minLength": 1
        },
        "fuel_type": {
          "type": "string",
          "minLength": 1
        },
        "build_type": {
          "type": "string",
          "minLength": 1
        },
        "machine_fault_code": {
          "type": "string",
          "minLength": 1
        },
        "fault_code_description": {
          "type": "string",
          "minLength": 1
        },
        "last_service_date_reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "billingAndCosting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "table_headings",
        "sundry_expenses",
        "fixed_expenses",
        "invoice_totals"
      ],
      "properties": {
        "table_headings": {
          "$ref": "#/$defs/tableHeadings"
        },
        "sundry_expenses": {
          "$ref": "#/$defs/sundryExpenses"
        },
        "fixed_expenses": {
          "$ref": "#/$defs/fixedExpenses"
        },
        "invoice_totals": {
          "$ref": "#/$defs/invoiceTotals"
        }
      }
    },
    "tableHeadings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "unit_cost",
        "quantity",
        "total"
      ],
      "properties": {
        "item": {
          "type": "string",
          "const": "Item"
        },
        "unit_cost": {
          "type": "string",
          "const": "Unit Cost"
        },
        "quantity": {
          "type": "string",
          "const": "Quantity"
        },
        "total": {
          "type": "string",
          "const": "Total"
        }
      }
    },
    "sundryExpenses": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_parts_and_spares",
        "components",
        "third_party_service_providers",
        "lubricants_and_concentrates",
        "consumables",
        "sundry_expenses_total"
      ],
      "properties": {
        "service_parts_and_spares": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chargeLineItem"
          }
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chargeLineItem"
          }
        },
        "third_party_service_providers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chargeLineItem"
          }
        },
        "lubricants_and_concentrates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chargeLineItem"
          }
        },
        "consumables": {
          "$ref": "#/$defs/consumables"
        },
        "sundry_expenses_total": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "chargeLineItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "unit_cost",
        "quantity",
        "total"
      ],
      "properties": {
        "item": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "supplier": {
          "type": "string",
          "minLength": 1
        },
        "part_number": {
          "type": "string",
          "minLength": 1
        },
        "unit_cost": {
          "type": "number",
          "minimum": 0
        },
        "quantity": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "consumables": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_cost",
        "scale_band",
        "applied_percentage",
        "total_cost"
      ],
      "properties": {
        "base_cost": {
          "type": "number",
          "minimum": 0,
          "description": "Sum of sundry expenses excluding consumables."
        },
        "scale_band": {
          "type": "string",
          "enum": [
            "R0.00-R1000.00",
            "R1000.01-R2500.00",
            "R2500.01-R5000.00",
            "Above R5000.00"
          ]
        },
        "applied_percentage": {
          "type": "number",
          "enum": [
            0.075,
            0.05,
            0.035,
            0.025
          ]
        },
        "total_cost": {
          "type": "number",
          "minimum": 0
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "fixedExpenses": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "call_out_fee",
        "procurement_fee",
        "labor",
        "fixed_expenses_total"
      ],
      "properties": {
        "call_out_fee": {
          "$ref": "#/$defs/chargeLineItem"
        },
        "procurement_fee": {
          "$ref": "#/$defs/chargeLineItem"
        },
        "labor": {
          "$ref": "#/$defs/chargeLineItem"
        },
        "fixed_expenses_total": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "invoiceTotals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_excluding_vat",
        "vat_rate",
        "vat_amount",
        "total_including_vat"
      ],
      "properties": {
        "total_excluding_vat": {
          "type": "number",
          "minimum": 0,
          "description": "Sum of sundry_expenses_total and fixed_expenses_total."
        },
        "vat_rate": {
          "type": "number",
          "const": 15
        }
        ,
        "vat_amount": {
          "type": "number",
          "minimum": 0
        },
        "total_including_vat": {
          "type": "number",
          "minimum": 0,
          "description": "total_excluding_vat * 115 / 100."
        }
      }
    }
  }
}
