# Client environment variables (non-secret; bundled into frontend)

# API Configuration
VITE_API_URL=https://localhost:5000
VITE_API_PROXY_TARGET=https://localhost:5000

# Local HTTPS development (Vite dev server)
# Store only file paths here; keep the actual certificate/key files local and untracked
VITE_SSL_ENABLED=true
VITE_SSL_CERT_FILE=../certs/localhost+1.pem
VITE_SSL_KEY_FILE=../certs/localhost+1-key.pem

# Google Maps API Key (restrict by HTTP referrer and API scope)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
