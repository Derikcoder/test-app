# Client environment variables (non-secret; bundled into frontend)

# API Configuration
# Development uses Vite proxy (/api). For production, set full API base URL.
# Example: https://your-backend-domain.com/api
VITE_API_URL=http://localhost:5000/api

# Google Maps API Key (restrict by HTTP referrer and API scope)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
