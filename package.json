{
  "name": "test-app",
  "version": "1.0.0",
  "description": "Full-stack MERN application",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "dev": "bash ./start-dev.sh",
    "refresh": "bash ./refresh.sh",
    "checkpoint": "bash ./scripts/create-checkpoint.sh",
    "checkpoint:recover": "bash ./scripts/recover-last-checkpoint.sh",
    "eod:new": "bash ./scripts/new-eod-entry.sh",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build:client": "npm run build --prefix client",
    "test:server": "npm test --prefix server",
    "test:client": "npm test --prefix client",
    "test": "npm run test:server && npm run test:client",
    "test:coverage": "npm run test:coverage --prefix server && npm run test:coverage --prefix client",
    "shutdown": "bash ./shutdown.sh"
  },
  "keywords": ["react", "express", "mongodb", "tailwind", "mern"],
  "author": "",
  "license": "ISC"
}
