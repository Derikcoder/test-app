# Node modules
node_modules/
*/node_modules/

# Environment variables
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
*/dist/
*/build/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing
coverage/
.nyc_output/

# Misc
.cache
.temp
*.pid
*.seed
*.pid.lock

# Local TLS certificate artifacts
# Development rule: track only docs/metadata and env-configured paths, never raw key/cert material
certs/*.pem
certs/*.key
certs/*.crt
certs/*.p12
certs/*.pfx
!certs/README.md
!certs/CERTIFICATE_INVENTORY.md
