{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wkd.local/schemas/invoice.schema.v1.json",
  "title": "WKD Invoice Schema v1",
  "description": "Invoice schema aligned to the defined invoiced-details logic, including structured sundry expenses, fixed expenses, VAT totals, and recommended consumables sliding-scale metadata.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/invoice"
  },
  "$defs": {
    "invoice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diensverskaffer_besonderhede",
        "klient_besonderhede",
        "faktuur_besonderhede",
        "diens_besonderhede",
        "faktureerde_besonderhede || koste_berekening",
        "diens_beskrywing"
      ],
      "properties": {
        "diensverskaffer_besonderhede": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/diensverskafferBesonderhede"
          }
        },
        "klient_besonderhede": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/klientBesonderhede"
          }
        },
        "faktuur_besonderhede": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/faktuurBesonderhede"
          }
        },
        "diens_besonderhede": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/diensBesonderhede"
          }
        },
        "faktureerde_besonderhede || koste_berekening": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/kosteBerekening"
          }
        },
        "diens_beskrywing": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "diensverskafferBesonderhede": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "besigheid_handeslnaam",
        "besigheid_registrasie_naam",
        "belasting_identifikasie_nommer",
        "btw_registrasie_nommer",
        "besigheid_adres",
        "besigheid_kontak_nommer",
        "besigheid_e-pos_adres",
        "besigheid_registrasie_webwerf"
      ],
      "properties": {
        "besigheid_handeslnaam": {
          "type": "string",
          "minLength": 1
        },
        "besigheid_registrasie_naam": {
          "type": "string",
          "minLength": 1
        },
        "belasting_identifikasie_nommer": {
          "type": "string",
          "minLength": 1
        },
        "btw_registrasie_nommer": {
          "type": "string",
          "minLength": 1
        },
        "besigheid_adres": {
          "type": "string",
          "minLength": 1
        },
        "besigheid_kontak_nommer": {
          "type": "string",
          "minLength": 1
        },
        "besigheid_e-pos_adres": {
          "type": "string",
          "format": "email"
        },
        "besigheid_registrasie_webwerf": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "klientBesonderhede": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "klient_tipe",
        "besigheid_naam",
        "besigheid_registrasie_nommer",
        "belasting_identifikasie_nommer",
        "btw_registrasie_nommer",
        "klient_adres",
        "kontak_persoon",
        "klient_kontak_nommer",
        "klient_e-pos_adres"
      ],
      "properties": {
        "klient_tipe": {
          "type": "string",
          "minLength": 1
        },
        "besigheid_naam": {
          "type": "string",
          "minLength": 1
        },
        "besigheid_registrasie_nommer": {
          "type": "string",
          "minLength": 1
        },
        "belasting_identifikasie_nommer": {
          "type": "string",
          "minLength": 1
        },
        "btw_registrasie_nommer": {
          "type": "string",
          "minLength": 1
        },
        "klient_adres": {
          "type": "string",
          "minLength": 1
        },
        "kontak_persoon": {
          "type": "string",
          "minLength": 1
        },
        "klient_kontak_nommer": {
          "type": "string",
          "minLength": 1
        },
        "klient_e-pos_adres": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "faktuurBesonderhede": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "faktuur_nommer",
        "faktuur_datum",
        "vervaldatum",
        "betalingsvoorwaardes",
        "valuta"
      ],
      "properties": {
        "faktuur_nommer": {
          "type": "string",
          "minLength": 1
        },
        "faktuur_datum": {
          "type": "string",
          "format": "date"
        },
        "vervaldatum": {
          "type": "string",
          "format": "date"
        },
        "betalingsvoorwaardes": {
          "type": "string",
          "minLength": 1
        },
        "valuta": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "diensBesonderhede": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diens_besonderhede",
        "masjien_besonderhede"
      ],
      "properties": {
        "diens_besonderhede": {
          "type": "string",
          "minLength": 1
        },
        "masjien_besonderhede": {
          "$ref": "#/$defs/masjienBesonderhede"
        }
      }
    },
    "masjienBesonderhede": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "masjien_tipe",
        "masjien_merk",
        "masjien_model",
        "masjien_serienommer",
        "kva_gradering",
        "huidige_masjien_ure",
        "masjine_ure_ten_laaste_diens",
        "brandstof_tipe",
        "bou_tipe",
        "masjien_foutkode",
        "foutkode_beskrywing",
        "datum_van_laaste_diens"
      ],
      "properties": {
        "masjien_tipe": {
          "type": "string",
          "minLength": 1
        },
        "masjien_merk": {
          "type": "string",
          "minLength": 1
        },
        "masjien_model": {
          "type": "string",
          "minLength": 1
        },
        "masjien_serienommer": {
          "type": "string",
          "minLength": 1
        },
        "kva_gradering": {
          "type": "string",
          "minLength": 1
        },
        "huidige_masjien_ure": {
          "type": "string",
          "minLength": 1
        },
        "masjine_ure_ten_laaste_diens": {
          "type": "string",
          "minLength": 1
        },
        "brandstof_tipe": {
          "type": "string",
          "minLength": 1
        },
        "bou_tipe": {
          "type": "string",
          "minLength": 1
        },
        "masjien_foutkode": {
          "type": "string",
          "minLength": 1
        },
        "foutkode_beskrywing": {
          "type": "string",
          "minLength": 1
        },
        "datum_van_laaste_diens": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "kosteBerekening": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "table_headings",
        "diverse_uitgawes",
        "vaste_uitgawes",
        "faktuur_totale_berekening"
      ],
      "properties": {
        "table_headings": {
          "$ref": "#/$defs/tableHeadings"
        },
        "diverse_uitgawes": {
          "$ref": "#/$defs/diverseUitgawes"
        },
        "vaste_uitgawes": {
          "$ref": "#/$defs/vasteUitgawes"
        },
        "faktuur_totale_berekening": {
          "$ref": "#/$defs/faktuurTotaleBerekening"
        }
      }
    },
    "tableHeadings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "unit_cost",
        "quantity",
        "total"
      ],
      "properties": {
        "item": {
          "type": "string",
          "const": "Item"
        },
        "unit_cost": {
          "type": "string",
          "const": "Unit Cost"
        },
        "quantity": {
          "type": "string",
          "const": "Quantity"
        },
        "total": {
          "type": "string",
          "const": "Total"
        }
      }
    },
    "diverseUitgawes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diens_parte_en_onderdele",
        "komponente",
        "derde_party_diens_verskaffers",
        "smeermiddels_en_konsentrate",
        "verbruikbare_voorraad",
        "diverse_uitgawes_totaal"
      ],
      "properties": {
        "diens_parte_en_onderdele": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chargeLineItem"
          }
        },
        "komponente": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chargeLineItem"
          }
        },
        "derde_party_diens_verskaffers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chargeLineItem"
          }
        },
        "smeermiddels_en_konsentrate": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chargeLineItem"
          }
        },
        "verbruikbare_voorraad": {
          "$ref": "#/$defs/verbruikbareVoorraad"
        },
        "diverse_uitgawes_totaal": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "chargeLineItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "unit_cost",
        "quantity",
        "total"
      ],
      "properties": {
        "item": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "supplier": {
          "type": "string",
          "minLength": 1
        },
        "part_number": {
          "type": "string",
          "minLength": 1
        },
        "unit_cost": {
          "type": "number",
          "minimum": 0
        },
        "quantity": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "verbruikbareVoorraad": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basis_koste",
        "skaal_band",
        "toegepaste_persentasie",
        "totaal_koste"
      ],
      "properties": {
        "basis_koste": {
          "type": "number",
          "minimum": 0,
          "description": "Sum of sundry expenses excluding consumables."
        },
        "skaal_band": {
          "type": "string",
          "enum": [
            "R0.00-R1000.00",
            "R1000.01-R2500.00",
            "R2500.01-R5000.00",
            "Above R5000.00"
          ]
        },
        "toegepaste_persentasie": {
          "type": "number",
          "enum": [
            0.075,
            0.05,
            0.035,
            0.025
          ],
          "description": "Recommended bracket rates: 7.5%, 5.0%, 3.5%, 2.5%."
        },
        "totaal_koste": {
          "type": "number",
          "minimum": 0
        },
        "nota": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "vasteUitgawes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uitroepfooi",
        "verkryging_koste",
        "arbeid",
        "vaste_uitgawes_totaal"
      ],
      "properties": {
        "uitroepfooi": {
          "$ref": "#/$defs/chargeLineItem"
        },
        "verkryging_koste": {
          "$ref": "#/$defs/chargeLineItem"
        },
        "arbeid": {
          "$ref": "#/$defs/chargeLineItem"
        },
        "vaste_uitgawes_totaal": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "faktuurTotaleBerekening": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totaal_btw_uitgesluit",
        "btw_persentasie",
        "btw_bedrag",
        "totaal_btw_ingesluit"
      ],
      "properties": {
        "totaal_btw_uitgesluit": {
          "type": "number",
          "minimum": 0,
          "description": "Sum of diverse_uitgawes_totaal and vaste_uitgawes_totaal."
        },
        "btw_persentasie": {
          "type": "number",
          "const": 15
        },
        "btw_bedrag": {
          "type": "number",
          "minimum": 0
        },
        "totaal_btw_ingesluit": {
          "type": "number",
          "minimum": 0,
          "description": "total_btw_uitgesluit * 115 / 100."
        }
      }
    }
  }
}
