{
  "name": "server",
  "version": "1.0.0",
  "description": "Backend server with Express and MongoDB",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:report:local": "node ./scripts/db-target-report.mjs --target local",
    "db:report:atlas": "node ./scripts/db-target-report.mjs --target atlas",
    "db:audit:duplicates:local": "node ./scripts/db-duplicate-audit.mjs --target local",
    "db:audit:duplicates:atlas": "node ./scripts/db-duplicate-audit.mjs --target atlas",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest --detectOpenHandles",
    "test:server": "npm run test",
    "test:server:json": "npm run test -- --json --outputFile=jest.output.json .",
    "test:watch": "node --experimental-vm-modules ./node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/.bin/jest --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "image-size": "^2.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb-connection-string-url": "7.0.1",
    "mongoose": "^8.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.7",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
