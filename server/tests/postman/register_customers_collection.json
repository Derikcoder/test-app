        {
          "name": "RC-SEC-006c Auth Bypass — Algorithm None JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// eyJhbGciOiJub25lIn0.e30. decodes to: alg:none, empty payload, no signature",
                  "// If the server accepts this, it is vulnerable to the 'alg:none' JWT attack.",
                  "pm.test('[RC-SEC-006c] Algorithm-none JWT returns 401 or 403', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403],",
                  "        'CRITICAL: alg:none JWT was accepted — auth is bypassable');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer eyJhbGciOiJub25lIn0.e30." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerType\": \"residential\",\n  \"contactFirstName\": \"AlgNone\",\n  \"contactLastName\": \"Attack\",\n  \"email\": \"algnone@example.com\",\n  \"phoneNumber\": \"0700000007\",\n  \"customerId\": \"CUST-ALGNONE-SEC006\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/customers",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "customers"]
            },
            "description": "RC-SEC-006: alg:none JWT (eyJhbGciOiJub25lIn0.e30.). If the server accepts this token, it is vulnerable to a critical auth bypass. Must return 401 or 403."
          }
