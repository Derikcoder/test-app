    {
      "name": "RC-SEC | Security Tests",
      "description": "Security probes: NoSQL injection, oversized input, auth bypass, and algorithm-none JWT.",
      "item": [
        {
          "name": "RC-SEC-003a NoSQL Injection in Email ($ne probe)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// RC-SEC-003: NoSQL injection probe",
                  "// Expected: 400 (validation rejects non-string) or type coercion by Mongoose",
                  "pm.test('[RC-SEC-003a] NoSQL injection { $ne: null } rejected or neutralized', function () {",
                  "    // If 201: the value was stored as a literal object (Mongoose coercion) — inspect DB",
                  "    // If 400: input validation correctly rejected the object type — PASS",
                  "    const status = pm.response.code;",
                  "    console.log('[RC-SEC-003a] Status:', status);",
                  "    console.log('[RC-SEC-003a] Body:', pm.response.text());",
                  "    pm.expect([400, 422]).to.include(status, 'Object-type email must be rejected with 400');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerType\": \"residential\",\n  \"contactFirstName\": \"Injection\",\n  \"contactLastName\": \"Test\",\n  \"email\": { \"$ne\": null },\n  \"phoneNumber\": \"0700000002\",\n  \"customerId\": \"CUST-NOSQL-001\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/customers",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "customers"]
            },
            "description": "RC-SEC-003: email field is a NoSQL operator object { $ne: null }. Expect 400 — if 201, investigate how the value was stored."
          }
        },
        {
          "name": "RC-SEC-003b NoSQL Injection in Email (OR probe)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[RC-SEC-003b] SQL-style OR string rejected as invalid email', function () {",
                  "    pm.response.to.have.status(400);",
                  "    console.log('[RC-SEC-003b] Body:', pm.response.text());",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerType\": \"residential\",\n  \"contactFirstName\": \"Injection\",\n  \"contactLastName\": \"Test\",\n  \"email\": \"test@x.com' OR '1'='1\",\n  \"phoneNumber\": \"0700000003\",\n  \"customerId\": \"CUST-NOSQL-002\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/customers",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "customers"]
            },
            "description": "RC-SEC-003: SQL-style injection in email field. Expect 400 from email regex validation."
          }
        },
        {
          "name": "RC-SEC-004 Oversized Input in Notes",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a 50,000 character string for the notes field",
                  "pm.collectionVariables.set('OVERSIZED_NOTES', 'A'.repeat(50000));",
                  "const ts = Date.now();",
                  "pm.collectionVariables.set('TS', ts);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[RC-SEC-004] Oversized input handled safely (no server crash)', function () {",
                  "    // Accept 201 (stored without size limit) or 400/413 (rejected by limit)",
                  "    pm.expect([201, 400, 413]).to.include(pm.response.code);",
                  "    console.log('[RC-SEC-004] Status:', pm.response.code);",
                  "    console.log('[RC-SEC-004] Response time (ms):', pm.response.responseTime);",
                  "    if (pm.response.responseTime > 5000) {",
                  "        console.warn('[RC-SEC-004] WARNING: Response took', pm.response.responseTime, 'ms — potential DoS risk');",
                  "    }",
                  "});",
                  "pm.test('[RC-SEC-004] Server responds (no timeout)', function () {",
                  "    pm.expect(pm.response.code).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerType\": \"residential\",\n  \"contactFirstName\": \"Oversized\",\n  \"contactLastName\": \"Input\",\n  \"email\": \"oversized+{{TS}}@example.com\",\n  \"phoneNumber\": \"0700000004\",\n  \"customerId\": \"CUST-OVERSIZED-{{TS}}\",\n  \"physicalAddressDetails\": {\n    \"streetAddress\": \"1 Big Street\",\n    \"suburb\": \"Bigtown\",\n    \"cityDistrict\": \"Cape Town\",\n    \"province\": \"Western Cape\",\n    \"postalCode\": \"8001\"\n  },\n  \"notes\": \"{{OVERSIZED_NOTES}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/customers",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "customers"]
            },
            "description": "RC-SEC-004: notes field contains 50,000 characters. Verifies no crash, no timeout cascade, response time is acceptable."
          }
        },
