{
  "info": {
    "_postman_id": "rc-e2e-test-suite-2026-03-24",
    "name": "Register Customers — E2E Test Suite",
    "description": "Postman API test collection for the customer registration end-to-end flow.\n\nCovers:\n- Happy path (create customer + service call)\n- RC-API-001 through RC-API-005 (server validation)\n- RC-DB-001 through RC-DB-003 (persistence verification via GET)\n- RC-NEG-001, RC-NEG-003 (negative cases)\n- RC-SEC-003, RC-SEC-004, RC-SEC-006 (security tests)\n\nSetup:\n1. Set BASE_URL collection variable to your backend URL (default: http://localhost:5000)\n2. Set AUTH_TOKEN to a valid JWT from POST /api/auth/login\n3. Run 'Setup & Happy Path' folder first — it populates CUSTOMER_OBJECT_ID and SERVICE_CALL_ID\n4. Then run remaining folders\n\nReferences:\n  register_customers_testcases.md\n  scripts/log-register-customers-test-result.sh",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000",
      "type": "string",
      "description": "Backend base URL. Default: http://localhost:5000"
    },
    {
      "key": "AUTH_TOKEN",
      "value": "REPLACE_WITH_YOUR_JWT",
      "type": "string",
      "description": "Valid JWT from POST /api/auth/login. Required for all protected routes."
    },
    {
      "key": "TS",
      "value": "",
      "type": "string",
      "description": "Timestamp — set automatically by pre-request scripts."
    },
    {
      "key": "CUSTOMER_ID_QA",
      "value": "",
      "type": "string",
      "description": "Test customer ID — set by the happy path pre-request script."
    },
    {
      "key": "CUSTOMER_OBJECT_ID",
      "value": "",
      "type": "string",
      "description": "MongoDB _id of the created customer — set by happy path test script."
    },
    {
      "key": "SERVICE_CALL_ID",
      "value": "",
      "type": "string",
      "description": "MongoDB _id of the created service call — set by happy path test script."
    }
  ],
  "item": [
    {
      "name": "Setup & Happy Path",
      "description": "Run this folder first. Creates a new customer and service call, and saves their IDs into collection variables for use in downstream tests.",
      "item": [
        {
          "name": "01 Happy Path — Create Customer (RC-UI-001 / RC-API)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a unique timestamp-based test ID for this run",
                  "const ts = Date.now();",
                  "pm.collectionVariables.set('TS', ts);",
                  "pm.collectionVariables.set('CUSTOMER_ID_QA', 'CUST-QA-' + ts);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// RC-API happy path assertions",
                  "pm.test('[RC-API Happy Path] Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('[RC-API Happy Path] Response has customer data', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('data');",
                  "    pm.expect(body.data).to.have.property('_id');",
                  "    pm.expect(body.data).to.have.property('customerId');",
                  "    pm.expect(body.data).to.have.property('createdBy');",
                  "});",
                  "",
                  "// RC-DB-003: createdBy must be present",
                  "pm.test('[RC-DB-003] createdBy field is present on response', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data.createdBy).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "// Save customer _id for downstream tests",
                  "const body = pm.response.json();",
                  "if (body.data && body.data._id) {",
                  "    pm.collectionVariables.set('CUSTOMER_OBJECT_ID', body.data._id);",
                  "    console.log('[RC-API Happy Path] CUSTOMER_OBJECT_ID set to:', body.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{AUTH_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerType\": \"residential\",\n  \"contactFirstName\": \"Test\",\n  \"contactLastName\": \"Customer\",\n  \"email\": \"qa+{{TS}}@example.com\",\n  \"phoneNumber\": \"0711111111\",\n  \"customerId\": \"{{CUSTOMER_ID_QA}}\",\n  \"physicalAddressDetails\": {\n    \"streetAddress\": \"1 QA Test Street\",\n    \"suburb\": \"Testville\",\n    \"cityDistrict\": \"Cape Town\",\n    \"province\": \"Western Cape\",\n    \"postalCode\": \"8001\"\n  },\n  \"notes\": \"Created by Postman QA runner\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/customers",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "customers"]
            },
            "description": "Happy path: create a valid residential customer. Pre-request script sets CUSTOMER_ID_QA. Test script saves CUSTOMER_OBJECT_ID."
          }
        },
        {
          "name": "02 Happy Path — Create Service Call (RC-DB-002)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[RC-DB-002] Service call created: status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('[RC-DB-002] Service call body has _id and customer ref', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data).to.have.property('_id');",
                  "    pm.expect(body.data).to.have.property('customer');",
                  "    pm.expect(body.data.customer).to.eql(pm.collectionVariables.get('CUSTOMER_OBJECT_ID'));",
                  "});",
                  "",
                  "// Save SERVICE_CALL_ID for RC-REC-003",
                  "const body = pm.response.json();",
                  "if (body.data && body.data._id) {",
                  "    pm.collectionVariables.set('SERVICE_CALL_ID', body.data._id);",
                  "    console.log('[RC-DB-002] SERVICE_CALL_ID set to:', body.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{AUTH_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": \"{{CUSTOMER_OBJECT_ID}}\",\n  \"serviceType\": \"generator-service\",\n  \"title\": \"QA Test Service Call\",\n  \"description\": \"Service call created during Postman QA registration test\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/service-calls",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "service-calls"]
            },
            "description": "Creates a service call linked to the customer created in step 01. Requires CUSTOMER_OBJECT_ID to be set."
          }
        },
        {
          "name": "03 DB Check — GET All Customers (RC-DB-001)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[RC-DB-001] GET customers returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[RC-DB-001] New customer appears in GET /api/customers response', function () {",
                  "    const body = pm.response.json();",
                  "    const customers = body.data || body;",
                  "    pm.expect(customers).to.be.an('array');",
                  "    const qaCustomerId = pm.collectionVariables.get('CUSTOMER_ID_QA');",
                  "    const found = customers.find(c => c.customerId === qaCustomerId);",
                  "    pm.expect(found, 'QA customer not found in list — DB persistence check failed').to.exist;",
                  "});",
                  "",
                  "pm.test('[RC-DB-003] All returned customers have createdBy field', function () {",
                  "    const body = pm.response.json();",
                  "    const customers = body.data || body;",
                  "    customers.forEach(c => {",
                  "        pm.expect(c.createdBy, 'createdBy missing on customer: ' + c.customerId).to.exist;",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{AUTH_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/customers",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "customers"]
            },
            "description": "Verifies DB persistence: the new customer must appear in GET /api/customers. Also checks createdBy scoping (RC-DB-003)."
          }
        }
      ]
    },
