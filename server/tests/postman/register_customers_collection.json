        {
          "name": "RC-API-004 Partial Write (Force Service Call Fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// This service call is deliberately missing 'title' and 'description'",
                  "pm.test('[RC-API-004] Missing title/description returns 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('[RC-API-004] IMPORTANT: The customer record from Setup step STILL EXISTS in DB', function () {",
                  "    // This test intentionally documents the partial-write risk.",
                  "    // Verify manually in MongoDB that the customer created in step 01 is still present.",
                  "    // There is no transaction rollback — this is expected current behavior.",
                  "    pm.expect(true).to.be.true; // Placeholder — verify DB manually",
                  "    console.log('[RC-API-004] Manual DB check required: customer should exist, service call should not.');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{AUTH_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": \"{{CUSTOMER_OBJECT_ID}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/service-calls",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "service-calls"]
            },
            "description": "RC-API-004: intentionally malformed service call (missing title, description). After this, the customer from step 01 should still exist in DB — demonstrating the sequential-write / no-transaction risk."
          }
        },
