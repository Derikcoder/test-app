PORT=5000
MONGODB_URI=mongodb://localhost:27017/test-app
NODE_ENV=development
JWT_SECRET=your-secret-key-change-this-in-production
# Store only file paths here; keep the actual certificate/key files local and untracked
SSL_ENABLED=true
SSL_CERT_FILE=../certs/localhost+1.pem
SSL_KEY_FILE=../certs/localhost+1-key.pem
# Comma-separated frontend origins allowed to call this API in browser.
# Example: https://your-frontend-domain.com,http://localhost:3000
CORS_ORIGIN=http://localhost:3000
