      "transform": "copy_string"
    },
    {
      "from": "faktureerde_besonderhede || koste_berekening[].lyn_items[].part_tipe",
      "to": "billing_and_costing[].line_items[].part_type",
      "transform": "copy_string"
    },
    {
      "from": "faktureerde_besonderhede || koste_berekening[].lyn_items[].fabrikaat",
