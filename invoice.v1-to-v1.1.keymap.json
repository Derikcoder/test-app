{
  "version": "1.1",
  "source_format": "invoice.schema.v1.json",
  "target_format": "invoice.schema.v1.1.json",
  "notes": [
    "Use this map when converting legacy v1 invoice payloads to v1.1 normalized payloads.",
    "Fields with transform hints need parsing/normalization logic.",
    "Array notation [] means apply mapping for each array item."
  ],
  "top_level": {
    "diensverskaffer_besonderhede": "service_provider_details",
    "klient_besonderhede": "client_details",
    "faktuur_besonderhede": "invoice_details",
    "diens_besonderhede": "service_details",
    "faktureerde_besonderhede || koste_berekening": "billing_and_costing",
    "diens_beskrywing": "service_description"
  },
