      "transform": "parse_currency_rate"
    },
    {
      "from": "faktureerde_besonderhede || koste_berekening[].vaste_uitgawes[].aantal_kilometers",
      "to": "billing_and_costing[].fixed_expenses[].distance_km",
      "transform": "parse_distance_km"
    },
    {
      "from": "faktureerde_besonderhede || koste_berekening[].vaste_uitgawes[].minimum_uitroepfooi",
      "to": "billing_and_costing[].fixed_expenses[].minimum_callout_fee",
      "transform": "parse_currency_amount"
    },
    {
      "from": "faktureerde_besonderhede || koste_berekening[].vaste_uitgawes[].uitroepfooi_totaal",
      "to": "billing_and_costing[].fixed_expenses[].callout_fee_total",
      "transform": "evaluate_formula_or_set_manual"
    },
    {
      "from": "faktureerde_besonderhede || koste_berekening[].faktuur_totale_berekening[]",
      "to": "billing_and_costing[].invoice_totals[]",
      "transform": "normalize_totals_object"
    },
    {
      "from": "diens_beskrywing[]",
      "to": "service_description[]",
      "transform": "copy_object"
    }
